---
const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="container footer-inner">
    <div class="footer-bottom">
      <p class="copyright">&copy; {year} Chase Cappo</p>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: var(--bg-deep);
    padding: 32px 0;
    border-top: 1px solid var(--border);
  }

  .footer-bottom {
    text-align: center;
  }

  .copyright {
    color: var(--text-dim);
    font-size: 0.85rem;
  }
</style>
