---
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout
  title="Chase Cappo"
  description="Coming soon."
>
  <section class="hero">
    <div class="container">
      <h1>chasecappo</h1>
      <p class="lede">Coming soon.</p>
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    padding: 120px 0 80px;
    text-align: center;
  }

  .hero h1 {
    font-size: clamp(3rem, 10vw, 6rem);
    color: var(--accent);
    letter-spacing: 0.04em;
    margin-bottom: 16px;
  }

  .lede {
    color: var(--text-muted);
    font-size: 1.1rem;
  }
</style>
