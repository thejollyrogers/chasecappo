---
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout
  title="Chase Cappo"
  description="Coming soon."
>
  <section class="hero">
    <div class="container">
      <h1>chasecappo</h1>
      <p class="lede">Coming soon.</p>
    </div>
  </section>

  <section class="book">
    <div class="container">
      <h2>Let's Connect</h2>
      <p class="book-copy">Interested in working together? Book a time that works for you.</p>
      <a
        href="https://calendar.app.google/XdKsqkaQyu6jxEcD6"
        target="_blank"
        rel="noopener noreferrer"
        class="btn"
      >
        Schedule a Meeting
      </a>
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    padding: 120px 0 80px;
    text-align: center;
  }

  .hero h1 {
    font-size: clamp(3rem, 10vw, 6rem);
    color: var(--accent);
    letter-spacing: 0.04em;
    margin-bottom: 16px;
  }

  .lede {
    color: var(--text-muted);
    font-size: 1.1rem;
  }

  .book {
    padding: 0 0 120px;
    text-align: center;
  }

  .book h2 {
    font-size: clamp(1.8rem, 5vw, 2.8rem);
    color: var(--accent);
    margin-bottom: 12px;
  }

  .book-copy {
    color: var(--text-muted);
    font-size: 1.05rem;
    margin-bottom: 28px;
  }
</style>
